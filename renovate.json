{
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "automergeType": "pr",
  "schedule": [
    "on the 1st day of the month"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": "at any time",
    "automerge": true,
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Major Updates",
      "automerge": false
    },
    {
      "groupName": "TypeScript definitions",
      "automerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    },
    {
      "groupName": "Babel",
      "automerge": true,
      "matchPackageNames": [
        "/^@babel//",
        "/^babel-/"
      ]
    },
    {
      "groupName": "ESLint",
      "automerge": true,
      "matchPackageNames": [
        "/^eslint/",
        "/^@typescript-eslint//"
      ]
    },
    {
      "groupName": "Testing",
      "automerge": true,
      "matchPackageNames": [
        "/^jest/",
        "/^@jest//",
        "/^@testing-library//"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "timezone": "UTC"
}